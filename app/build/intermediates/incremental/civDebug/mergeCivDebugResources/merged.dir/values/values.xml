<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="darker_gray">#121212</color>
    <color name="heading_yellow">#dfb228</color>
    <color name="isp_panel_bg">#202326</color>
    <color name="isp_tile_bg">#30363a</color>
    <color name="isp_tile_pressed">#44505a</color>
    <color name="isp_tile_stroke">#667078</color>
    <color name="white">#ffffff</color>
    <dimen name="auto_margin">6dp</dimen>
    <dimen name="fontSize">14sp</dimen>
    <dimen name="isp_tile_height">92dp</dimen>
    <dimen name="isp_tile_icon">32dp</dimen>
    <dimen name="isp_tile_label">12sp</dimen>
    <string name="app_desc">Drag ISP route development markers onto the ATAK map.</string>
    <string name="app_name">ISP Routes</string>
    <string name="marker_check_point">Check Point</string>
    <string name="marker_cnp_left">CNP - Left Turn</string>
    <string name="marker_cnp_other">CNP - Other</string>
    <string name="marker_cnp_right">CNP - Right Turn</string>
    <string name="marker_gas_station">Gas Station</string>
    <string name="marker_hospital">Hospital</string>
    <string name="marker_loi">LOI</string>
    <string name="marker_overpass">Overpass</string>
    <string name="marker_police_station">Police Station</string>
    <string name="marker_restricted">Restricted</string>
    <string name="marker_school">School</string>
    <string name="marker_tunnel">Tunnel</string>
    <string name="versionName" translatable="false">0.1 () - [5.5.0]</string>
    <style name="ATAKEditText" parent="@android:style/Widget.EditText">
        
        

        
        <item name="android:imeOptions">flagNoFullscreen</item>
    </style>
    <style name="ATAKPluginTheme" parent="@android:style/Theme.Holo">
        <item name="android:textAppearanceLargePopupMenu">@style/PopupMenuTextAppearance</item>
        <item name="android:buttonStyle">@android:style/Widget.Button</item>
        <item name="android:imageButtonStyle">@android:style/Widget.Button</item>
        <item name="android:buttonStyleToggle">@android:style/Widget.Button</item>
        <item name="android:spinnerStyle">@style/ATAKSpinner</item>
        <item name="android:spinnerItemStyle">@style/ATAKSpinnerItem</item>
        <item name="android:spinnerDropDownItemStyle">@style/ATAKSpinnerDropDownItem</item>
        <item name="android:editTextStyle">@style/ATAKEditText</item>
    </style>
    <style name="ATAKSpinner" parent="@android:style/Widget.Spinner">
        <item name="android:spinnerMode">dialog</item>
    </style>
    <style name="ATAKSpinnerDropDownItem" parent="@style/ATAKSpinnerItem">
        <item name="android:paddingStart">@dimen/auto_margin</item>
    </style>
    <style name="ATAKSpinnerItem">
        <item name="android:textColor">@android:color/white</item>
        <item name="android:dropDownVerticalOffset">0dip</item>
        <item name="android:dropDownHorizontalOffset">0dip</item>
        <item name="android:dropDownWidth">wrap_content</item>
        <item name="android:gravity">left|center_vertical</item>
    </style>
    <style name="ATAKTheme" parent="@android:style/Theme.Holo">

        
        <item name="android:buttonStyle">@android:style/Widget.Button</item>
        <item name="android:imageButtonStyle">@android:style/Widget.Button</item>
        <item name="android:buttonStyleToggle">@android:style/Widget.Button</item>
        <item name="android:spinnerStyle">@style/ATAKSpinner</item>
        <item name="android:spinnerItemStyle">@style/ATAKSpinnerItem</item>

        <item name="android:editTextStyle">@style/ATAKEditText</item>

        
        
    </style>
    <style name="AppBaseTheme" parent="android:Theme.Light">
        
    </style>
    <style name="AppTheme" parent="@android:style/Theme.Holo">
        <item name="android:buttonStyle">@android:style/Widget.Button</item>
        <item name="android:imageButtonStyle">@android:style/Widget.Button</item>
        <item name="android:buttonStyleToggle">@android:style/Widget.Button</item>
        <item name="android:spinnerStyle">@style/ATAKSpinner</item>
        <item name="android:spinnerItemStyle">@style/ATAKSpinnerItem</item>
        <item name="android:editTextStyle">@style/ATAKEditText</item>
    </style>
    <style name="FullDropdownStyle" parent="@style/ATAKTheme">
        <item name="android:buttonStyle">@style/unpaddedButton</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:imeOptions">flagNoExtractUi</item>
    </style>
    <style name="ISPRoutesTile">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">@dimen/isp_tile_height</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_gravity">fill_horizontal</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
        <item name="android:background">@drawable/isp_tile_bg</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:padding">6dp</item>
    </style>
    <style name="ISPRoutesTileIcon">
        <item name="android:layout_width">@dimen/isp_tile_icon</item>
        <item name="android:layout_height">@dimen/isp_tile_icon</item>
    </style>
    <style name="ISPRoutesTileLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">6dp</item>
        <item name="android:gravity">center</item>
        <item name="android:maxLines">2</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/isp_tile_label</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="PopupMenuTextAppearance" parent="android:TextAppearance.Large">
        <item name="android:textColor">@color/white</item>
    </style>
    <style name="darkButton" parent="@android:style/Widget.Button">
        <item name="android:background">@drawable/btn_gray</item>
        <item name="android:shadowColor">@color/darker_gray</item>
        <item name="android:shadowDy">1</item>
        <item name="android:shadowRadius">2</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">3dp</item>
        <item name="android:textSize">@dimen/fontSize</item>
    </style>
    <style name="unpaddedButton" parent="@android:style/Widget.Button">
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">3dp</item>
        <item name="android:textSize">@dimen/fontSize</item>
    </style>
</resources>